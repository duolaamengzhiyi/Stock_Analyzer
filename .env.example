# ====== 此文件仅占位，禁止填入真实值。本机配置请写入 .env.local（已加入 .gitignore）======

# ---------- Supabase（Vercel Supabase Integration 自动注入）----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---------- Postgres（同上）----------
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_HOST=

# ---------- DeepSeek（仅 Vercel 侧；Sealos 侧用同一组）----------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_STOCK_INTRO=deepseek-v4-pro
DEEPSEEK_MODEL_STOCK_ANALYSIS=deepseek-v4-pro

# ---------- AKTools（Sealos 侧自部署 akfamily/aktools）----------
AKTOOLS_BASE_URL=

# ---------- 站点 URL（Supabase Auth 邮箱回调使用）----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

