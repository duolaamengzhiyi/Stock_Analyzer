# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---- Node / Next.js ----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts

# ---- testing / coverage ----
/coverage
*.lcov
.vitest-cache
.nyc_output

# ---- env files（仅 .example 入仓）----
.env
.env.*
!.env.example

# ---- vercel ----
.vercel

# ---- Python (sealos/scheduler) ----
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ---- Drizzle migrations 派生产物（保留 .sql，忽略 meta journal 锁文件之外的临时缓存）----
# 实际 *.sql 与 meta/_journal.json 需要入仓；这里只忽略本地缓存
lib/db/migrations/.cache/

# ---- IDE / OS ----
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/

# ---- debug logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- MCP / 临时产物 ----
.tmp/
*.swp
